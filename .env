# Voice Processing APIs
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
WHISPER_MODEL=whisper-1
COQUI_TTS_API_URL=http://localhost:5002
COQUI_TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
WEBSOCKET_PATH=/ws

# SMS Service (for OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
TWILIO_API_URL=https://api.twilio.com/2010-04-01

# File Upload
MAX_FILE_SIZE=26214400
UPLOAD_DIR=uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,audio/mpeg,audio/wav,audio/webm

# Security
CORS_ORIGIN=http://localhost:5000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your-session-secret-key

# WebRTC Configuration
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_PASSWORD=your-turn-password

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# API Rate Limiting
TRANSLATION_RATE_LIMIT=100
VOICE_RATE_LIMIT=50
OTP_RATE_LIMIT=5

# Feature Flags
ENABLE_VOICE_TRANSLATION=true
ENABLE_TEXT_TRANSLATION=true
ENABLE_E2E_ENCRYPTION=true
ENABLE_CONTACT_SYNC=true

# Monitoring
SENTRY_DSN=your-sentry-dsn
ANALYTICS_KEY=your-analytics-key